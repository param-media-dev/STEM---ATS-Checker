rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - isPro: boolean
    //   - createdAt: timestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "paramatwork3076@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (data.email.size() < 256) &&
             (!('proUntil' in data) || data.proUntil == null || data.proUntil is string);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.isPro == resource.data.isPro || isAdmin())) ||
                    (isAdmin() && isValidUser(request.resource.data));
    }
  }
}
